{
    ///
    /// Dart Extension
    ///
    "dart.flutterSdkPath": ".fvm/flutter_sdk",
    "dart.debugSdkLibraries": true,
    "dart.lineLength": 150,
    "dart.previewFlutterUiGuides": true,
    "dart.analysisExcludedFolders": [
        ".dart_tool",
        ".fvm",
        ".idea",
        ".vscode",
        "android",
        "assets",
        "build",
        "ios",
    ],
    ///
    /// VS Code
    ///
    "search.exclude": {
        "**/.fvm": true
    },
    "files.watcherExclude": {
        "**/.fvm": true
    },
    "[dart]": {
        "editor.defaultFormatter": "Dart-Code.dart-code",
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            150
        ],
        "editor.selectionHighlight": true,
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit",
            "quickfix.add.required": "explicit",
            "quickfix.add.required.multi": "explicit",
            "quickfix.create.constructorForFinalFields": "explicit"
        }
    },
    ///
    /// Dart Class Generator Extension
    ///
    "dart_data_class_generator.constructor.default_values": true,
    "dart_data_class_generator.fromJson.enabled": false,
    "dart_data_class_generator.fromMap.default_values": true,
    "dart_data_class_generator.toJson.enabled": false,
    "dart_data_class_generator.toString.enabled": false,
}